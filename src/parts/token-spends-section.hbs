<section class="token-spends">

  {{#if (eq item.system.cardType "job")}}
  <div class="flex-row">
    <div>
      <label>
        Job Base Pay
      </label>
      <input class="short" type="number" name="system.jobPay.base" value="{{item.system.jobPay.base}}">
    </div>
    <div>
      <label>
        Per token
      </label>
      <input class="short" type="number" name="system.jobPay.token" value="{{item.system.jobPay.token}}">
    </div>
  </div>
  {{/if}}

  <div>
    <h3> Token Spends</h3>
    <a class="add-token-spend">
      <i class="fa-solid fa-plus"> </i>
    </a>
  </div>
  {{#each item.system.tokenSpends as |spend i|}}

  <div class="token-spend" data-spend-index="{{i}}">
    <input class="short" type="number" name="system.tokenSpends.{{i}}.amount" value="{{spend.amount}}">
    <input class="tokenspend" name="system.tokenSpends.{{i}}.text" type:"string" value="{{spend.text}}">
    <a class="del-token-spend">
      <i class="fa-solid fa-trash"></i>
    </a>
  </div>

  {{/each}}
</section>

