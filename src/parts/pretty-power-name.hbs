<span class="tooltip pretty-power-name {{#if (not (canUsePower user power))}} unusable {{/if}}">
  <span class="power-type-icon">
    {{displayPowerIcon power user}}
  </span>
  <span class="power-name">
    {{power.displayedName}}
  </span>
  {{#if (isPowerOnCooldown user power)}}
  <span class="cooldown" title="On Cooldown">
    <i class="fa-solid fa-clock"></i>
  </span>
  {{/if}}
  <div class="tooltiptext">
    {{> "systems/persona/parts/power-tooltip-lite.hbs" power=power persona=user}}
  </div>
</span>
