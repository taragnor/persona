
{{> "systems/persona/parts/defenses-section.hbs" CONST=CONST persona=persona}}

{{> "systems/persona/parts/resistance-section.hbs" CONST=CONST persona=persona hideNormal=true}}

{{> "systems/persona/parts/basic-powers-section.hbs" CONST=CONST persona=persona actor=actor disabled=(not (isCombatPanelActive))}}

{{#if engagedList}}
<img src="systems/persona/img/icon/engaged-icon.gif" title="Engaged By {{#each engagedList as |comb i|}} {{comb.name}} {{/each}}">
{{/if}}

<section class="main-powers">
  {{> "systems/persona/parts/bubble-power-list.hbs" CONST=CONST persona=persona powerList=persona.displayedMainSkills}}
</section>

<section class="theurgies">
  {{> "systems/persona/parts/bubble-power-list.hbs" CONST=CONST persona=persona powerList=persona.theurgies}}
</section>

<section class="bonus-powers">
  {{> "systems/persona/parts/bubble-power-list.hbs" CONST=CONST persona=persona powerList=persona.displayedBonusPowers}}
</section>


{{#if false}}
<div class="main-powers">
  {{#each persona.activeCombatPowers as |power i|}}
  <div class="main-power {{#if (not (canUsePower ../persona power))}} faded {{/if}} {{#if (isSpecialPower ../persona power)}} shimmer {{/if}}" data-power-id="{{power.id}}" >
    <div class="power-name-block">
      <div class="power-name-bubble-container">
        {{> "systems/persona/parts/pretty-power-name.hbs" CONST=../CONST power=power user=../persona}}
      </div>
    </div>
  </div>
  {{/each}}
</div>
{{/if}}

<hr>
