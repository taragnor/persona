<div class="powers-section">
	<h2>
		{{localize 	"persona.statistic.powers"}}
		{{#if showPowerTableButton}}
		<a class="showPowersTable">
			<i class="fa-solid fa-table-list"></i>
		</a>
		{{/if}}

		{{#if (and (isShadow actor) (isGM))}}
		<a class="addShadowPower">
			<i class="fa-solid fa-plus"> </i>
		</a>
		{{/if}}
	</h2>
{{> "systems/persona/parts/basic-powers-section.hbs" CONST=CONST persona=persona activePowersOnly=activePowersOnly canDelete=canDelete showSideboard=showSideboard usePowers=usePowers actor=actor}}

{{#if false}}
{{> "systems/persona/parts/main-powers-table.hbs" CONST=CONST persona=persona activePowersOnly=activePowersOnly canDelete=canDelete showSideboard=showSideboard usePowers=usePowers}}
{{/if}}

<div class="main-powers">
  {{> "systems/persona/parts/power-table.hbs" CONST=CONST persona=persona powerList=persona.activeCombatPowers usePowers=usePowers}}
</div>


{{#if (and (canUseSideboard actor) showSideboard)}}
<section class="power-sideboard">
  <h3> Sideboarded Powers (max {{persona.maxSideboardPowers}}) </h3>
  <div class="power-sideboard">
    {{#each actor.sideboardPowers as |power i|}}
    <div class="sideboard-power" data-power-id="{{power.id}}">
      <div class="power-name-block {{#if (lte ../persona.maxSideboardPowers i)}} over-max-power {{/if}} {{#if (isPowerIllegal ../persona power)}} illegal-level {{/if}} {{#if (isPowerOnCooldown ../persona power)}} on-cooldown{{/if}}">
        <a class="powerName">
          {{> "systems/persona/parts/pretty-power-name.hbs" CONST=../CONST power=power user=../persona}}
          <span class="cost-string">
            {{powerCostString power ../persona}}
          </span>
        </a>
      </div>
      <div class="power-operations">
        {{#if false}}
        {{#if (eq ../actor.system.type "pc")}}
        <a class="move-to-main" title="Move to Main powers">
          <i class="fa-solid fa-truck-ramp-box"></i>
        </a>
        {{/if}}
        <a class="delPower" title="Delete Power">
          <i class="fa-solid fa-trash-can"></i>
        </a>
        {{/if}}
      </div>
    </div>
    {{/each}}
  </div>
</section>
{{/if}}

{{> "systems/persona/parts/next-learned-powers-section.hbs" CONST=CONST persona=persona actor=actor usePowers=usePowers showLearnedBuffer=showLearnedBuffer}}

{{> "systems/persona/parts/navigator-skills-section.hbs" CONST=CONST persona=persona actor=actor usePowers=usePowers}}

{{> "systems/persona/parts/sub-power-list.hbs" CONST=CONST persona=persona actor=actor usePowers=usePowers list=persona.theurgies listName="Theurgies"}}

{{#if showBonusPowers}}
{{> "systems/persona/parts/bonus-powers-table.hbs" CONST=CONST persona=persona actor=actor usePowers=usePowers}}
{{/if}}

</div>

