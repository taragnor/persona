<div class="scan-dialog {{#if (not persona.user.isOwner)}} non-owner {{/if}}">
  <header>
    {{> "systems/persona/parts/scan-sheet-header.hbs" persona=persona}}
  </header>
  <hr>
  {{#if (scanLevelgte persona 1)}}
  {{> "systems/persona/parts/defenses-section.hbs" CONST=CONST persona=persona}}

  {{> "systems/persona/parts/resistance-section.hbs" CONST=CONST persona=persona hideNormal=hideNormal}}
  {{/if}}

  {{#if (scanLevelgte persona 2)}}
  <h3> Powers</h3>
  <div class="main-powers">
    {{> "systems/persona/parts/bubble-power-list.hbs" CONST=CONST persona=persona powerList=persona.mainPowers}}

    <h3>Openers</h3>
    <div class="openers">
      {{> "systems/persona/parts/bubble-power-list.hbs" CONST=CONST persona=persona powerList=persona.openers}}
    </div>

  </div>

  {{/if}}
  {{#if showTreasure}}
  {{#if (scanLevelgte persona 2)}}
  {{#if (isShadow persona.user)}}
  <div class="treasure">
    <span><b> Treasure: </b></span>
    <span>
      {{actor.treasureString}}
    </span>
  </div>
  {{/if}}
  {{/if}}
  {{/if}}
</div>
