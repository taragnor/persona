{{#if list}}
<section class="power-sub-list">
  <h3> {{listName}} </h3>
  <div class="power-list power-sub-list">
    {{#each list as |power i|}}
    <div class="sub-list-power" data-power-id="{{power.id}}">
      <div class="power-name-block {{#if (isPowerOnCooldown ../persona power)}} on-cooldown{{/if}}">
        <a class="powerName">
          {{> "systems/persona/parts/pretty-power-name.hbs" CONST=../CONST power=power user=../persona}}
          <span class="cost-string">
            {{powerCostString power ../persona}}
          </span>
        </a>
      </div>
      <div class="power-operations">
        {{#if (canDeletePowers ../persona power)}}
        <a class="delPower" title="Delete Power">
          <i class="fa-solid fa-trash-can"></i>
        </a>
        {{/if}}
      </div>
    </div>
    {{/each}}
  </div>
</section>
{{/if}}
