<section class="items f-col">
  <div class="item-list">
    {{#each itemlist as |item|}}
    <div class="{{#if (ne item.system.noTrade true)}} item item-entry {{/if}} inventory-item" data-item-id="{{item.id}}" title="{{item.tooltip}}">
      <span class="f-row height-100">
        <span class="item-icon">
          {{displayIcon item}}
        </span>
        <span class="itemName">
          {{item.displayedNameHTML}}
          {{#if (gt item.amount 1)}}
          <span class="amount">
            ( {{item.amount}} )
          </span>
          {{/if}}
        </span>
        <a class="delItem">
          <i class="fa-solid fa-trash-can"></i>
        </a>
      </span>
    </div>
    {{/each}}
  </div>

</section>

