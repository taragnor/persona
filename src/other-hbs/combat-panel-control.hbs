{{#if (eq mode "tactical")}}
<h2 title="right click to exit"> Tactical View </h2>
<hr>
{{/if}}
<div class="control-panel {{#if (isCombatPanelActive)}}active-control-panel{{/if}} {{#if (eq mode 'tactical')}}tactical-view{{/if}}">
	<header>
		<h3 class="token-name"> {{token.name}}</h3>
		{{#if actor.canSwitchPersonas}}
		<div>
			<b>
				Active Persona:
			</b>
			<span class="persona-name">
				{{persona.name}}
			</span>
		</div>
		{{/if}}
		{{> "systems/persona/parts/vitals-section.hbs" CONST=CONST persona=persona}}
    {{> "systems/persona/parts/room-modifiers-list.hbs" roomModifiers=roomModifiers}}
	</header>
	<hr>
	<body>
		{{#if (eq mode "main")}}
		{{> "systems/persona/parts/combat-panel-control-body-main.hbs" CONST=CONST persona=persona actor=persona.user}}
		{{/if}}
	</body>
</div>
